# Crazy Monkey demo — Supabase connection
# Copy this file to .env and fill in values from:
# Supabase Dashboard → Project Settings → API

# Project URL (no trailing slash)
VITE_SUPABASE_URL=https://your-project-ref.supabase.co

# Legacy anon JWT key (starts with eyJ...). Required for @supabase/supabase-js.
# Do NOT use the service_role key in the frontend.
# If you only see sb_publishable_..., enable "Legacy API Keys" in Project Settings → API.
VITE_SUPABASE_ANON_KEY=your-anon-jwt-key
